# Normalize line endings
* text=auto

# C# source files
*.cs text diff=csharp

# Solution & project files
*.sln text
*.csproj text
*.props text
*.targets text

# Config files
*.json text
*.xml text
*.config text

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Entity Framework
*.Designer.cs text diff=csharp

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.exe binary